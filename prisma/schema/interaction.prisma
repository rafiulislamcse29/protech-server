model Review {
  id         String   @id @default(uuid()) @db.Uuid
  rating     Int
  comment    String?  @db.Text
  sentiment  Float?
  aiSummary  String?
  userId     String   @db.Uuid
  propertyId String   @db.Uuid
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@map("reviews")
  @@index([userId])
  @@index([propertyId])
}

model SavedProperty {
  userId     String   @db.Uuid
  propertyId String   @db.Uuid
  savedAt    DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([userId, propertyId])
  @@map("saved_properties")
  @@index([userId])
  @@index([propertyId])
}

model Inquiry {
  id         String        @id @default(uuid()) @db.Uuid
  buyerId    String        @db.Uuid
  agentId    String        @db.Uuid
  propertyId String        @db.Uuid
  message    String        @db.Text
  status     InquiryStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  buyer      User          @relation("BuyerInquiries", fields: [buyerId], references: [id])
  agent      Agent         @relation("AgentInquiries", fields: [agentId], references: [id])
  property   Property      @relation(fields: [propertyId], references: [id])

  @@map("inquiries")
  @@index([buyerId])
  @@index([agentId])
  @@index([propertyId])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  message   String
  link      String?
  metadata  Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([userId])
}

model SearchPreference {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @db.Uuid
  keywords    String[]
  avgPrice    Decimal  @db.Decimal(12, 2)
  targetAreas String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("search_preferences")
  @@index([userId])
}

model AIRecommendation {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  propertyId String   @db.Uuid
  reason     String
  score      Float
  viewed     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("ai_recommendations")
  @@index([userId])
  @@index([propertyId])
}
